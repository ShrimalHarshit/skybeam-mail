# ─── SkyBeam Mail Platform — Environment Variables ─────────────────────────
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Password for the skybeam DB user.
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# ─── API Server ──────────────────────────────────────────────────────────────
API_ADDR=:8080

# 32-byte random secret for token signing.
# Generate: openssl rand -hex 32
API_SECRET=CHANGE_ME_replace_with_64_char_hex_string

# ─── Dovecot Internal Auth ───────────────────────────────────────────────────
# These credentials are used by the watcher and reconciler to impersonate
# any mailbox user via Dovecot's master-user mechanism.
# Must match the entry in deploy/dovecot/conf/master-users
DOVECOT_MASTER_USER=skybeam_internal
DOVECOT_MASTER_PASS=CHANGE_ME_strong_dovecot_master_password

# ─── Hostnames (Caddy uses these to obtain TLS certificates) ─────────────────
# The API endpoint — Caddy gets a Let's Encrypt cert for this domain.
# Point your DNS A record here before starting the stack.
API_HOSTNAME=api.skybeam.studio

# The mail server hostname. Used by Postfix (MX record) and Caddy
# (redirects to API_HOSTNAME). Must match your PTR record.
MAIL_HOSTNAME=mail.skybeam.studio

# The domain you're receiving mail for.
MAIL_DOMAIN=skybeam.studio

# ─── Session Config ──────────────────────────────────────────────────────────
SESSION_TTL_DAYS=30

# ─── Reconciler ──────────────────────────────────────────────────────────────
RECONCILER_LIGHT_INTERVAL=5m
RECONCILER_FULL_INTERVAL=24h

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# LOG_FORMAT: json (production) | pretty (development)
LOG_FORMAT=json

# ─── TLS (Automatic via Caddy) ───────────────────────────────────────────────
# Caddy obtains and renews Let's Encrypt certificates automatically.
# No cert files to manage. No Certbot. No cron jobs.
#
# Required: set ACME_EMAIL to your real address. Let's Encrypt uses this
# only to send you expiry warnings (as a last resort — Caddy auto-renews).
ACME_EMAIL=ops@skybeam.studio
#
# DNS checklist before first boot:
#   A  api.skybeam.studio    → <your server IP>
#   A  mail.skybeam.studio   → <your server IP>
#   MX skybeam.studio        → mail.skybeam.studio (priority 10)
#   PTR <your server IP>     → mail.skybeam.studio
#
# Caddy performs HTTP-01 challenge on port 80. Ensure port 80 and 443
# are reachable from the internet before starting.
